MONGODB_URI=your_mongodb_connection_string
PORT=3001
FRONTEND_URL=https://your-frontend-domain.vercel.app
PUBLIC_BACKEND_URL=https://your-backend-domain.onrender.com
JWT_SECRET=generate_a_secure_random_secret
ADMIN_INTERNAL_API_KEY=generate_a_secure_internal_api_key
ADMIN_API_BASE_URL=https://your-admin-backend-domain.onrender.com
ADMIN_BACKEND_URL=https://your-admin-backend-domain.onrender.com
ADMIN_CREDENTIALS_ENDPOINT_PATH=/api/user/credentials
META_API_VERSION=v22.0
META_ACCESS_TOKEN=your_meta_access_token
META_AD_ACCOUNT_ID=your_meta_ad_account_id
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_PAGE_ID=your_facebook_page_id
META_PIXEL_ID=your_meta_pixel_id
META_ADS_FORCE_MOCK=false
META_ADVANTAGE_AUDIENCE=0
META_DEFAULT_BID_STRATEGY=LOWEST_COST_WITH_BID_CAP
META_BID_AMOUNT=5000
META_TOKEN_ENCRYPTION_KEY=32_characters_minimum_random_key
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=meta-ads

# Google Calendar / Meet integration
# Option 1: set GOOGLE_ACCESS_TOKEN directly (short-lived)
GOOGLE_ACCESS_TOKEN=
# Option 2: set refresh-token flow values (recommended for long-running backend)
GOOGLE_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/google-calendar/oauth/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=32_characters_minimum_random_key
ENABLE_DEBUG_LOGS=false
